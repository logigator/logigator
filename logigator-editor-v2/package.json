{
	"name": "logigator-editor-v2",
	"version": "0.0.0",
	"description": "Logigator Editor",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/logigator/logigator.git"
	},
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build && run build:purgecss && run build:sizereport",
		"build:purgecss": "cd dist/logigator-editor-v2/browser && purgecss --css '*.css' --content '*.{html,js}' --output .",
		"build:sizereport": "cd dist/logigator-editor-v2/browser && file-size --gzip --brotli --total *.{html,js,css}",
		"watch": "ng build --watch --configuration development",
		"format": "prettier . -c",
		"format:fix": "prettier . -lw",
		"lint": "ng lint",
		"lint:fix": "ng lint --fix",
		"test": "ng test"
	},
	"private": true,
	"dependencies": {
		"@angular/animations": "^21.2.10",
		"@angular/cdk": "^21.2.8",
		"@angular/common": "^21.2.10",
		"@angular/compiler": "^21.2.10",
		"@angular/core": "^21.2.10",
		"@angular/forms": "^21.2.10",
		"@angular/platform-browser": "^21.2.10",
		"@angular/platform-browser-dynamic": "^21.2.10",
		"@angular/router": "file:./packages/router-stub",
		"@jsverse/transloco": "^8.3.0",
		"@primeuix/themes": "^2.0.3",
		"pixi.js": "^8.18.1",
		"primeng": "^21.1.6",
		"regexparam": "^3.0.0",
		"rxjs": "~7.8.2",
		"tslib": "^2.8.1",
		"zone.js": "~0.15.1"
	},
	"devDependencies": {
		"@angular-devkit/core": "^21.2.8",
		"@angular-devkit/schematics": "^21.2.8",
		"@angular-eslint/builder": "^21.3.1",
		"@angular/build": "^21.2.8",
		"@angular/cli": "^21.2.8",
		"@angular/compiler-cli": "^21.2.10",
		"@eslint/js": "^10.0.1",
		"@phosphor-icons/web": "^2.1.2",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/jasmine": "~5.1.4",
		"angular-eslint": "^21.3.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"jasmine-core": "~5.2.0",
		"karma": "~6.4.4",
		"karma-chrome-launcher": "~3.2.0",
		"karma-coverage": "~2.2.1",
		"karma-jasmine": "~5.1.0",
		"karma-jasmine-html-reporter": "~2.1.0",
		"postcss": "^8.5.3",
		"prettier": "^3.8.3",
		"purgecss": "^8.0.0",
		"tailwindcss": "^4.2.4",
		"tailwindcss-primeui": "^0.6.1",
		"tiny-file-size": "^0.4.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.59.0"
	},
	"packageManager": "yarn@4.14.1"
}
